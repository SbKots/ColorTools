<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>

    <PackageId>SbKots.ColorTools</PackageId>
    <Version>1.0.0</Version>
    <Authors>SbKots</Authors>
    <Company>SbKots</Company>
    <Description>Библиотека для преобразования между цветовыми моделями RGB, HEX, HSL и базовых операций с цветами.</Description>
    <PackageTags>color;rgb;hex;hsl;nuget</PackageTags>
    <RepositoryUrl>https://github.com/SbKots/ColorTools</RepositoryUrl>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

</Project>